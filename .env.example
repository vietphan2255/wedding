# Copy this file to .env.local and fill in real values from your Firebase project
# Project settings → Your apps → Web app → SDK setup and configuration
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
# Google Analytics (GA4). Optional — omit to disable analytics. Firebase Console
# → Project settings → Your apps → Web app → measurementId.
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Cloudinary — free image & audio uploads from the admin (no credit card needed).
# cloudinary.com → Settings → Upload → add an UNSIGNED upload preset.
# Set the preset's "Resource type" to Auto so background-music audio uploads too.
# Cloud name is shown at the top of the dashboard.
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset

# App Check (reCAPTCHA v3) — optional but recommended. Firebase Console → App Check
# → register this web app with reCAPTCHA v3, paste the site key here, then enable
# enforcement on Realtime Database (and Authentication). Blocks scripted abuse,
# quota-exhaustion DoS, and self-signup from non-app clients.
VITE_RECAPTCHA_SITE_KEY=6Ld0czwtAAAAANsKv-Iz8JXM-d6Y_9-908kqsmYH

# NOTE: /admin sign-in now uses Firebase Authentication (email/password), not an
# env var. Create the admin user in Firebase Console → Authentication and put its
# UID(s) into database.rules.json (replace ADMIN_UID_1 / ADMIN_UID_2). There is no VITE_ADMIN_PASSWORD
# anymore — a VITE_ var ships in the public bundle and could never be a real secret.
